# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram chat ID (send /start to the bot to see it)
TELEGRAM_CHAT_ID=123456789

# Optional: leave blank to skip Wise signature verification
WISE_WEBHOOK_SECRET=

# Wise API token — required to fetch sender name and payment reference
# Generate at: https://wise.com/settings/api-tokens (read-only scope is enough)
WISE_API_TOKEN=

# Leave as-is for SQLite (no setup needed)
DATABASE_URL=sqlite:///./badminton.db
